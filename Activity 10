Aim: To load clean and explore data using Python

import pandas as pd
data = {
    "Name": ["Ram", "Sam", "Tom", None],
    "Marks": [85, 90, None, 75],
    "City": ["Delhi", "Mumbai", "Chennai", "Bangalore"]
}
df = pd.DataFrame(data)
print("Original Data")
print(df)
Replace missing values with 0
df["Marks"] = df["Marks"].fillna(0)
Replace missing names with 'Unknown'
df["Name"] = df["Name"].fillna("Unknown")
print("\nCleaned Data")
print(df)
print("\nFirst 2 Rows")
print(df.head(2))
print("\nData Information")
print(df.info())
print("\nStatistical Summary")
print(df.describe())

